# Copy this file to .env and fill in your values.
# Never commit your real .env file to version control.

# TikTok user access token obtained through your OAuth 2.0 flow.
# This token is scoped to a single TikTok user account.
TIKTOK_ACCESS_TOKEN=act.your_access_token_here

# Optional: override the default HTTP request timeout (seconds).
# TIKTOK_TIMEOUT=30
